---
const testimonials = [
  {
    quote: "Darwin nos desarrollo toda la plataforma de e-commerce y las automatizaciones de inventario. Las ventas se triplicaron en los primeros 3 meses. Un profesional excepcional.",
    name: "Carlos Mendoza",
    role: "CEO, Omega Store",
    image: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop&crop=face"
  },
  {
    quote: "Nos ayudo a migrar toda nuestra infraestructura a AWS y automatizar procesos que antes tomaban dias. Ahora todo funciona en minutos. Totalmente recomendado.",
    name: "Andrea Torres",
    role: "CTO, W Capital Tech",
    image: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&h=100&fit=crop&crop=face"
  },
  {
    quote: "La web que nos creo para el estudio de abogados fue exactamente lo que necesitabamos: profesional, rapida y que genera confianza. Los nuevos clientes llegan solos.",
    name: "Dr. Luis Ramirez",
    role: "Socio, ECLA Abogados",
    image: "https://images.unsplash.com/photo-1560250097-0b93528c311a?w=100&h=100&fit=crop&crop=face"
  }
];
---

<section class="section section-alt">
  <div class="container">
    <div class="section-header">
      <span class="label">Testimonios</span>
      <h2>Lo que dicen <span class="gradient-text">mis clientes</span></h2>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((t) => (
        <div class="testimonial-card card">
          <div class="quote-mark">"</div>
          <p class="quote-text">{t.quote}</p>
          <div class="quote-author">
            <img src={t.image} alt={t.name} loading="lazy" />
            <div>
              <strong>{t.name}</strong>
              <span>{t.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    position: relative;
    padding: 2.5rem 2rem 2rem;
  }

  .quote-mark {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 4rem;
    line-height: 1;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: -0.5rem;
  }

  .quote-text {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .quote-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .quote-author img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(6, 182, 212, 0.3);
  }

  .quote-author strong {
    display: block;
    font-size: 0.85rem;
    color: #fff;
  }

  .quote-author span {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 968px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }
</style>
