---
---

<section class="section" id="contacto">
  <div class="container">
    <div class="section-header">
      <span class="label">Contacto</span>
      <h2>Hagamos realidad <span class="gradient-text">tu proyecto</span></h2>
      <p>Cuentame sobre tu negocio y te preparo una propuesta personalizada.</p>
    </div>
    <div class="contact-grid">
      <form class="contact-form" action="https://formspree.io/f/placeholder" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombre" placeholder="Tu nombre completo" required />
          </div>
          <div class="form-group">
            <label for="empresa">Empresa</label>
            <input type="text" id="empresa" name="empresa" placeholder="Nombre de tu empresa" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="tu@email.com" required />
          </div>
          <div class="form-group">
            <label for="servicio">Servicio de interes</label>
            <select id="servicio" name="servicio">
              <option value="">Selecciona un servicio</option>
              <option value="web">Desarrollo Web</option>
              <option value="software">Software a Medida</option>
              <option value="automatizacion">Automatizaciones & IA</option>
              <option value="ecommerce">E-commerce</option>
              <option value="marketing">Marketing Digital</option>
              <option value="cloud">Cloud & DevOps</option>
              <option value="integral">Todo incluido</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="mensaje">Cuentame sobre tu proyecto</label>
          <textarea id="mensaje" name="mensaje" rows="4" placeholder="Describe tu proyecto, objetivos y plazos..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Enviar mensaje &rarr;</button>
      </form>

      <div class="contact-info">
        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>
          <h3>Email</h3>
          <p>darwin97.va@gmail.com</p>
        </div>
        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          </div>
          <h3>Ubicacion</h3>
          <p>Lima, Peru</p>
        </div>
        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.182-5.568a4.5 4.5 0 00-6.364 6.364L12 10.5"/></svg>
          </div>
          <h3>Links</h3>
          <div class="info-links">
            <a href="https://github.com/darwinva97" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://linkedin.com/in/darwinva" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="https://twitter.com/Darwin97VA" target="_blank" rel="noopener noreferrer">Twitter</a>
          </div>
        </div>
        <div class="info-card highlight">
          <h3>Agenda una llamada</h3>
          <p>30 minutos gratuitos para conocer tu proyecto y proponerte soluciones reales.</p>
          <a href="mailto:darwin97.va@gmail.com?subject=Quiero%20agendar%20una%20llamada" class="btn btn-primary" style="margin-top:1rem;font-size:0.85rem;">Agendar ahora &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .contact-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    backdrop-filter: blur(10px);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .form-group:last-child {
    margin-bottom: 1.25rem;
  }

  .btn-full {
    width: 100%;
    justify-content: center;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1.5rem;
    backdrop-filter: blur(10px);
  }

  .info-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(6, 182, 212, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
    color: var(--accent-1);
  }

  .info-card h3 {
    font-size: 0.95rem;
    margin-bottom: 0.375rem;
  }

  .info-card p {
    color: var(--text-light);
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.6;
  }

  .info-links {
    display: flex;
    gap: 1rem;
  }

  .info-links a {
    font-size: 0.85rem;
    color: var(--accent-1);
    transition: color 0.3s;
    font-weight: 500;
  }

  .info-links a:hover {
    color: #fff;
  }

  .info-card.highlight {
    background: var(--gradient);
    border-color: transparent;
  }

  .info-card.highlight h3 {
    color: #fff;
  }

  .info-card.highlight p {
    color: rgba(255,255,255,0.85);
  }

  @media (max-width: 968px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    .contact-form {
      padding: 1.5rem;
    }
  }
</style>
