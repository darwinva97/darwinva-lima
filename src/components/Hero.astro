---
---

<section class="hero" id="inicio">
  <div class="hero-bg">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-grid-pattern"></div>
  </div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Disponible para proyectos
      </div>
      <h1>
        Construyo software, <br/>
        <span class="gradient-text">automatizo procesos</span> <br/>
        y escalo negocios en Lima
      </h1>
      <p class="hero-desc">
        Fullstack Developer & DevOps con +6 anos de experiencia.
        Desde landing pages hasta plataformas complejas con IA,
        automatizaciones y marketing digital que genera resultados reales.
      </p>
      <div class="hero-buttons">
        <a href="/#portafolio" class="btn btn-primary">Ver Portafolio &rarr;</a>
        <a href="/#contacto" class="btn btn-secondary">Agendar Reunion</a>
      </div>
    </div>

    <div class="hero-stats-bar">
      <div class="stat-item">
        <span class="stat-value">+50</span>
        <span class="stat-label">Proyectos entregados</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">+6</span>
        <span class="stat-label">Anos de experiencia</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">+20</span>
        <span class="stat-label">Clientes activos</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">AWS</span>
        <span class="stat-label">Cloud certified</span>
      </div>
    </div>

    <div class="hero-clients">
      <p class="clients-label">Empresas que confiaron en mi trabajo</p>
      <div class="clients-logos">
        <span>W Capital Tech</span>
        <span>ECLA Abogados</span>
        <span>Habitos Group</span>
        <span>N&A Construcciones</span>
        <span>FMA Tech</span>
        <span>Universidad Ame</span>
        <span>Cobra Peru</span>
        <span>MKT Sideral</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--primary);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 8rem 0 4rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(6, 182, 212, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6, 182, 212, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 40%, transparent 100%);
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .hero-orb-1 {
    width: 600px;
    height: 600px;
    background: rgba(6, 182, 212, 0.15);
    top: -15%;
    right: -10%;
    animation: float 10s ease-in-out infinite;
  }

  .hero-orb-2 {
    width: 400px;
    height: 400px;
    background: rgba(124, 58, 237, 0.12);
    bottom: -10%;
    left: -5%;
    animation: float 12s ease-in-out infinite reverse;
  }

  .hero-orb-3 {
    width: 200px;
    height: 200px;
    background: rgba(236, 72, 153, 0.1);
    top: 40%;
    left: 40%;
    animation: float 8s ease-in-out infinite 2s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-25px) scale(1.05); }
  }

  .hero-content {
    position: relative;
    max-width: 800px;
    animation: slide-up 0.8s ease-out;
  }

  @keyframes slide-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.2);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent-1);
    margin-bottom: 2rem;
    letter-spacing: 0.5px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    margin-bottom: 1.5rem;
    line-height: 1.1;
    letter-spacing: -1px;
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--text-light);
    max-width: 580px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-stats-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 5rem;
    padding: 2rem 3rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(10px);
    animation: slide-up 0.8s ease-out 0.3s both;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  .hero-clients {
    margin-top: 4rem;
    text-align: center;
    animation: slide-up 0.8s ease-out 0.6s both;
  }

  .clients-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .clients-logos {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
  }

  .clients-logos span {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 1px;
    transition: color 0.3s;
  }

  .clients-logos span:hover {
    color: rgba(255,255,255,0.5);
  }

  @media (max-width: 768px) {
    .hero-stats-bar {
      flex-wrap: wrap;
      gap: 1.5rem;
      padding: 1.5rem;
      justify-content: center;
    }
    .stat-divider {
      display: none;
    }
    .stat-item {
      flex: 1 1 40%;
    }
    .stat-value {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 7rem 0 3rem;
    }
    .hero-stats-bar {
      margin-top: 3rem;
    }
  }
</style>
