---
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-icon">
        <svg width="28" height="28" viewBox="0 0 36 36" fill="none">
          <defs>
            <linearGradient id="logo-g" x1="0" y1="0" x2="36" y2="36">
              <stop offset="0%" stop-color="#06b6d4"/>
              <stop offset="100%" stop-color="#7c3aed"/>
            </linearGradient>
          </defs>
          <rect width="36" height="36" rx="8" fill="url(#logo-g)"/>
          <text x="50%" y="52%" dominant-baseline="central" text-anchor="middle" fill="#fff" font-family="Space Grotesk,sans-serif" font-weight="700" font-size="18">D</text>
        </svg>
      </span>
      <span class="logo-text">DARWINVA</span>
    </a>
    <nav class="nav">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#portafolio">Portafolio</a>
      <a href="/#tecnologias">Stack</a>
      <a href="/#proceso">Proceso</a>
      <a href="/#contacto">Contacto</a>
    </nav>
    <a href="/#contacto" class="btn btn-primary header-cta">Hablemos</a>
    <button class="mobile-toggle" aria-label="Menu" id="menuToggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <nav class="mobile-nav" id="mobileNav">
    <a href="/#inicio">Inicio</a>
    <a href="/#servicios">Servicios</a>
    <a href="/#portafolio">Portafolio</a>
    <a href="/#tecnologias">Stack</a>
    <a href="/#proceso">Proceso</a>
    <a href="/#contacto">Contacto</a>
    <a href="/#contacto" class="btn btn-primary" style="margin-top:0.5rem;">Hablemos</a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menuToggle');
  const nav = document.getElementById('mobileNav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    toggle.classList.toggle('active');
  });
  nav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      nav.classList.remove('open');
      toggle?.classList.remove('active');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 26, 0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(6, 182, 212, 0.1);
    padding: 0.75rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    color: #fff;
    text-decoration: none;
  }

  .logo-icon {
    display: flex;
  }

  .logo-text {
    letter-spacing: 3px;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav a {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.3s;
    text-decoration: none;
    position: relative;
  }

  .nav a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gradient);
    transition: width 0.3s;
  }

  .nav a:hover {
    color: #fff;
  }

  .nav a:hover::after {
    width: 100%;
  }

  .header-cta {
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .mobile-toggle span {
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: 0.3s;
  }

  .mobile-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .mobile-toggle.active span:nth-child(2) {
    opacity: 0;
  }
  .mobile-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    gap: 0.75rem;
    background: rgba(10, 10, 26, 0.98);
    border-bottom: 1px solid var(--border);
  }

  .mobile-nav a {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    padding: 0.5rem 0;
    transition: color 0.3s;
  }

  .mobile-nav a:hover {
    color: #fff;
  }

  .mobile-nav.open {
    display: flex;
  }

  @media (max-width: 968px) {
    .nav, .header-cta {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
  }
</style>
